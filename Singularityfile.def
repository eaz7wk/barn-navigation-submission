Bootstrap: docker
From: ros:noetic

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/jackal_ws/src

%files
    . /jackal_ws/src/the-barn-challenge

%post -c /bin/bash
    set -e
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y --no-install-recommends \
        keyboard-configuration \
        tzdata \
        python3-venv \
        python3-pip \
        git \
        curl \
        build-essential \
        cmake \
        pkg-config \
        python3-rosdep \
        python3-rosinstall \
        python3-rosinstall-generator \
        python3-wstool \
        python3-empy \
        python3-catkin-pkg \
        ros-noetic-catkin \
        ros-noetic-navigation \
        ros-noetic-base-local-planner \
        ros-noetic-control-toolbox \
        ros-noetic-costmap-2d \
        ros-noetic-nav-core \
        ros-noetic-move-base \
        ros-noetic-pluginlib \
        ros-noetic-tf \
        ros-noetic-tf2 \
        ros-noetic-tf2-ros \
        ros-noetic-tf2-eigen \
        ros-noetic-eigen-conversions \
        ros-noetic-pcl-ros \
        ros-noetic-pcl-conversions \
        ros-noetic-rviz \
        ros-noetic-xacro \
        ros-noetic-gazebo-ros \
        ros-noetic-gazebo-plugins \
        ros-noetic-gazebo-msgs \
        ros-noetic-hector-gazebo-plugins \
        ros-noetic-twist-mux \
        ros-noetic-sick-tim \
        ros-noetic-lms1xx \
        ros-noetic-pointgrey-camera-description \
        ros-noetic-velodyne-description \
        ros-noetic-rosdoc-lite \
        ros-noetic-geometry-msgs \
        ros-noetic-sensor-msgs \
        ros-noetic-nav-msgs \
        ros-noetic-std-msgs \
        ros-noetic-visualization-msgs \
        ros-noetic-message-generation \
        ros-noetic-message-runtime \
        ros-noetic-robot-state-publisher \
        ros-noetic-joint-state-publisher \
        ros-noetic-joint-state-publisher-gui \
        ros-noetic-urdf \
        ros-noetic-robot-localization \
        ros-noetic-angles \
        ros-noetic-dynamic-reconfigure \
        ros-noetic-roscpp \
        ros-noetic-rospy \
        ros-noetic-std-srvs \
        ros-noetic-actionlib \
        ros-noetic-actionlib-msgs \
        ros-noetic-cv-bridge \
        ros-noetic-image-transport \
        ros-noetic-ros-controllers \
        ros-noetic-controller-manager \
        ros-noetic-jackal-simulator \
        ros-noetic-jackal-desktop \
        ros-noetic-jackal-navigation \
        ros-noetic-interactive-marker-twist-server \
        libgazebo11-dev \
        libprotobuf-dev \
        protobuf-compiler \
        libeigen3-dev

    python3 -m venv /venv
    export PATH="/venv/bin:$PATH"

    pip3 install --upgrade pip
    pip3 install "empy==3.3.4" defusedxml rospkg netifaces numpy

    cd /jackal_ws/src
    git clone https://github.com/jackal/jackal.git --branch noetic-devel
    git clone https://github.com/utexas-bwi/eband_local_planner.git || true

    source /opt/ros/noetic/setup.bash
    cd /jackal_ws
    catkin_make

%environment
    export PATH="/venv/bin:$PATH"
